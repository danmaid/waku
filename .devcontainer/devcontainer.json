{
	"image": "registry.access.redhat.com/ubi9/httpd-24",
	"overrideCommand": true,
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {},
		"ghcr.io/devcontainers/features/git:1": {}
	},
	"mounts": [
		"source=${localWorkspaceFolder},target=/workspace,type=bind",
		"source=${localWorkspaceFolder}/public,target=/var/www/html,type=bind",
		"source=${localWorkspaceFolder}/config/httpd/dev.conf,target=/etc/httpd/conf.d/dev.conf,type=bind"
	],
	"postCreateCommand": "bash /workspace/.devcontainer/dev-prestart.sh",
	"postStartCommand": "httpd"
}