{
	"name": "Go DevContainer",
	"build": {
		"dockerfile": "Dockerfile"
	},
	   "runArgs": [
		   "--init",
		"--privileged",
		"--add-host=host.docker.internal:host-gateway"
	   ],
	"mounts": [
		"source=${localWorkspaceFolder}/public,target=/workspaces/waku/public,type=bind",
		"source=${localWorkspaceFolder}/config,target=/workspaces/waku/config,type=bind",
		// docker.sock のマウントはDinDでは不要
	],
	"features": {},
	"postCreateCommand": "/usr/local/bin/start-dind.sh && go mod download && go build -o bin/dynamic-proxy main.go",
	"postStartCommand": "sudo docker compose up -d",
	"customizations": {
		"vscode": {
			"settings": {},
			"extensions": [
				"golang.Go"
			]
		}
	}
}